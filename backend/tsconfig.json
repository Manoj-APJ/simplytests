{
    "compilerOptions": {
        "target": "ES2020",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "rootDir": "./src",
        "outDir": "./dist",
        "esModuleInterop": true,
        "strict": false,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "ignoreDeprecations": "6.0"
    },
    "include": [
        "src",
        "prisma"
    ],
    "exclude": [
        "node_modules"
    ]
}